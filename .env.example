APP_ENV=production
APP_DEBUG=false
APP_URL=https://ranker.example.com
APP_NAME=RS3 Clan Discord Ranker
TIMEZONE=Australia/Sydney

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rs3_clan_ranker
DB_USER=ranker_user
DB_PASS=change_me
DB_CHARSET=utf8mb4

DISCORD_BOT_TOKEN=replace_with_your_bot_token
DISCORD_CLIENT_ID=123456789012345678
DISCORD_CLIENT_SECRET=replace_with_your_client_secret
DISCORD_REDIRECT_URI=https://ranker.example.com/auth/discord/callback.php
DISCORD_GUILD_ID=123456789012345678

CLAN_ID=1
CLAN_NAME=24K

# Optional comma-separated Discord IDs.
# If both are blank, any member of the configured guild can access the admin UI.
ADMIN_DISCORD_USER_IDS=
ADMIN_DISCORD_ROLE_IDS=

SESSION_NAME=rs3_ranker_admin
SESSION_SECRET=replace_with_a_long_random_secret

# Discord settings are configured in the admin UI:
# - Log Channel
# - Enable/Disable Private Message on Change to Guest
# - Guest Private Message contents
